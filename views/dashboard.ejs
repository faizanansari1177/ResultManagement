<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Student Portal</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f4f6fb; min-height: 100vh; }

    /* Navbar */
    nav {
      background: linear-gradient(135deg, #667eea, #764ba2);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand { color: white; font-size: 1.2rem; font-weight: 700; }
    .nav-brand span { font-size: 1.3rem; }
    .logout-btn {
      color: white;
      text-decoration: none;
      background: rgba(255,255,255,0.2);
      padding: 0.4rem 1rem;
      border-radius: 20px;
      font-size: 0.9rem;
      transition: background 0.2s;
    }
    .logout-btn:hover { background: rgba(255,255,255,0.35); }

    /* Container */
    .container { max-width: 720px; margin: 2rem auto; padding: 0 1rem; }

    /* Welcome Banner */
    .welcome-banner {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      padding: 1.8rem 2rem;
      border-radius: 14px;
      margin-bottom: 1.5rem;
    }
    .welcome-banner h2 { font-size: 1.5rem; margin-bottom: 0.3rem; }
    .welcome-banner p { opacity: 0.85; font-size: 0.9rem; }

    /* Card */
    .card {
      background: white;
      border-radius: 14px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.07);
      margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .card-header {
      background: #f8f9ff;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #eee;
      font-weight: 700;
      color: #444;
      font-size: 0.95rem;
    }
    .info-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.9rem 1.5rem;
      border-bottom: 1px solid #f5f5f5;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: #888; font-size: 0.88rem; }
    .info-value { color: #333; font-weight: 600; font-size: 0.95rem; }

    /* Result Button */
    .result-btn {
      display: block;
      width: 100%;
      padding: 1rem;
      background: linear-gradient(135deg, #11998e, #38ef7d);
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 1.05rem;
      font-weight: 700;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .result-btn:hover { opacity: 0.9; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-brand"><span>🎓</span> Student Portal</div>
    <a href="/logout" class="logout-btn">Logout</a>
  </nav>

  <div class="container">
    <div class="welcome-banner">
      <h2>Welcome, <%= user.name %>! 👋</h2>
      <p>Here is your student profile information.</p>
    </div>

    <div class="card">
      <div class="card-header">📋 Personal Information</div>
      <div class="info-row">
        <span class="info-label">Full Name</span>
        <span class="info-value"><%= user.name %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Email Address</span>
        <span class="info-value"><%= user.email %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Father's Name</span>
        <span class="info-value"><%= user.fatherName %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Mother's Name</span>
        <span class="info-value"><%= user.motherName %></span>
      </div>
    </div>

    <a href="/result" class="result-btn">📊 Show Result</a>
  </div>
</body>
</html>

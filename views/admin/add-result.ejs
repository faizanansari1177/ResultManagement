    input:focus, select:focus { outline: none; border-color: #8b0000; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.8rem; }
    .grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 0.8rem; }


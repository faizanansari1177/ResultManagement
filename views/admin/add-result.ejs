<script>
function addRow(containerId, prefix) {
  const c = document.getElementById(containerId);
  const d = document.createElement('div');
  d.className = 'sub-row';
  d.innerHTML = `
    <input type="text" name="${prefix}Code"      placeholder="Code">
    <input type="text" name="${prefix}ExtMM"     placeholder="70">
    <input type="text" name="${prefix}ExtMarks"  placeholder="0">
    <input type="text" name="${prefix}SessMM"    placeholder="30">
    <input type="text" name="${prefix}SessMarks" placeholder="0">
    <input type="text" name="${prefix}Total"     placeholder="0">
    <button type="button" class="remove-btn" onclick="removeRow(this,'${containerId}')">×</button>
  `;
  c.appendChild(d);
  updateBtns(containerId);
}
function removeRow(btn, containerId) {
  btn.closest('.sub-row').remove();
  updateBtns(containerId);
}
function updateBtns(containerId) {
  const rows = document.querySelectorAll('#' + containerId + ' .sub-row');
  rows.forEach(r => r.querySelector('.remove-btn').disabled = rows.length === 1);
}
  function previewLogo(input) {
    if (input.files && input.files[0]) {
      var reader = new FileReader();
      reader.onload = function(e) {
        var box = document.getElementById('logoPreviewBox');
        box.innerHTML = '<img src="' + e.target.result + '" alt="Logo Preview">';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
  function setSemLabels(val) {
    const map = {
      'I_II':   ['I SEMESTER',   'II SEMESTER'],
      'III_IV': ['III SEMESTER', 'IV SEMESTER'],
      'V_VI':   ['V SEMESTER',   'VI SEMESTER']
    };
    if (map[val]) {
      document.getElementById('sem1Name').value = map[val][0];
      document.getElementById('sem2Name').value = map[val][1];
    }
  }
</script>
</body>
</html>

      align-items: center; justify-content: center;
      background: #fafafa; flex-shrink: 0; overflow: hidden;
    }
    .logo-preview-box img { width: 100%; height: 100%; object-fit: contain; }
    .logo-preview-box p { font-size: 0.7rem; color: #aaa; margin-top: 0.3rem; }
    .logo-upload-info { flex: 1; }
    .upload-label {
      display: inline-block; padding: 0.5rem 1rem;
      background: #fff0f0; color: #8b0000;
      border: 1.5px solid #8b0000; border-radius: 6px;

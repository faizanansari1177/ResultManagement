    .submit-btn:hover { background: #6b0000; }
    .alert { padding: 0.8rem 1rem; border-radius: 8px; margin-bottom: 1.2rem; font-size: 0.9rem; }
    .alert-success { background: #f0fff4; color: #27ae60; border-left: 4px solid #27ae60; }
    .alert-error { background: #fff0f0; color: #e53935; border-left: 4px solid #e53935; }


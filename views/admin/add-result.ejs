    .add-btn { background: #fff0f0; color: #8b0000; border: 1.5px dashed #8b0000; border-radius: 6px; padding: 0.4rem 0.8rem; font-size: 0.8rem; font-weight: 600; cursor: pointer; width: 100%; margin-top: 0.3rem; }
    .add-btn:hover { background: #ffe8e8; }


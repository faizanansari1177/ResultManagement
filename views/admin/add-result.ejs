            <option value="I_II">I / II Semester</option>
            <option value="III_IV">III / IV Semester</option>
            <option value="V_VI">V / VI Semester</option>
          </select>
          <!-- Hidden fields auto-filled by JS -->
          <input type="hidden" name="sem1Name" id="sem1Name">
          <input type="hidden" name="sem2Name" id="sem2Name">
      </div>
    </div>

    <!-- Two Semester Subjects Side by Side -->
    <div class="semesters-grid">

      <!-- SEM 1 -->
      <div class="sem-panel">
        <div class="sem-title">Semester 1 Subjects</div>
        <div class="sub-header">
          <span>Sub Code</span><span>Ext.MM</span><span>Ext.Marks</span><span>Sess.MM</span><span>Sess.Marks</span><span>Total</span><span></span>
        </div>
        <div id="sem1-container">
          <div class="sub-row">
            <input type="text"   name="s1Code"      placeholder="BAS101">
            <input type="text"   name="s1ExtMM"     placeholder="70">
            <input type="text"   name="s1ExtMarks"  placeholder="21">
            <input type="text"   name="s1SessMM"    placeholder="30">
            <input type="text"   name="s1SessMarks" placeholder="27">
            <input type="text"   name="s1Total"     placeholder="48">
            <button type="button" class="remove-btn" onclick="removeRow(this,'sem1-container')" disabled>×</button>
          </div>
        </div>
        <button type="button" class="add-btn" onclick="addRow('sem1-container','s1')">+ Add Row</button>
      </div>

      <!-- SEM 2 -->
      <div class="sem-panel">
        <div class="sem-title">Semester 2 Subjects</div>
        <div class="sub-header">
          <span>Sub Code</span><span>Ext.MM</span><span>Ext.Marks</span><span>Sess.MM</span><span>Sess.Marks</span><span>Total</span><span></span>
        </div>
        <div id="sem2-container">
          <div class="sub-row">
            <input type="text"   name="s2Code"      placeholder="BAS201">
            <input type="text"   name="s2ExtMM"     placeholder="70">
            <input type="text"   name="s2ExtMarks"  placeholder="37">
            <input type="text"   name="s2SessMM"    placeholder="30">
            <input type="text"   name="s2SessMarks" placeholder="18">
            <input type="text"   name="s2Total"     placeholder="55">
            <button type="button" class="remove-btn" onclick="removeRow(this,'sem2-container')" disabled>×</button>
          </div>
        </div>
        <button type="button" class="add-btn" onclick="addRow('sem2-container','s2')">+ Add Row</button>
      </div>

    </div>

    <!-- Summary -->
    <div class="card" style="margin-top:1rem;">
      <div class="card-title">📋 Summary & Result</div>
      <div class="grid-2">
        <div class="form-group"><label>Carry Over Paper(s)</label><input type="text" name="carryOverPapers" placeholder="Leave blank if none"></div>
        <div class="form-group"><label>Year Label</label><input type="text" name="yearLabel" placeholder="FIRST YEAR" value="FIRST YEAR"></div>
      </div>
      <div class="grid-4">
        <div class="form-group"><label>Maximum Marks</label><input type="text" name="maximumMarks" placeholder="1400" required></div>
        <div class="form-group"><label>Marks Obtained</label><input type="text" name="marksObtain" placeholder="865" required></div>
        <div class="form-group">
          <label>Result</label>
          <select name="result" required>
            <option value="">-- Select --</option>
            <option value="PASS">PASS</option>
            <option value="FAIL">FAIL</option>
            <option value="COMPARTMENT">COMPARTMENT</option>
          </select>
        </div>
        <div class="form-group"><label>Date of Declaration</label><input type="text" name="dateOfDeclaration" placeholder="14 Sep 2015" required></div>
      </div>
    </div>

    <button type="submit" class="submit-btn">💾 Save Marksheet</button>
  </form>
</div>

<script>
function addRow(containerId, prefix) {
  const c = document.getElementById(containerId);
  const d = document.createElement('div');
  d.className = 'sub-row';
  d.innerHTML = `
    <input type="text" name="${prefix}Code"      placeholder="Code">
    <input type="text" name="${prefix}ExtMM"     placeholder="70">
    <input type="text" name="${prefix}ExtMarks"  placeholder="0">
    <input type="text" name="${prefix}SessMM"    placeholder="30">
    <input type="text" name="${prefix}SessMarks" placeholder="0">
    <input type="text" name="${prefix}Total"     placeholder="0">
    <button type="button" class="remove-btn" onclick="removeRow(this,'${containerId}')">×</button>
  `;
  c.appendChild(d);
  updateBtns(containerId);
}
function removeRow(btn, containerId) {
  btn.closest('.sub-row').remove();
  updateBtns(containerId);
}
function updateBtns(containerId) {
  const rows = document.querySelectorAll('#' + containerId + ' .sub-row');
  rows.forEach(r => r.querySelector('.remove-btn').disabled = rows.length === 1);
}
  function previewLogo(input) {
    if (input.files && input.files[0]) {
      var reader = new FileReader();
      reader.onload = function(e) {
        var box = document.getElementById('logoPreviewBox');
        box.innerHTML = '<img src="' + e.target.result + '" alt="Logo Preview">';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
  function setSemLabels(val) {
    const map = {
      'I_II':   ['I SEMESTER',   'II SEMESTER'],
      'III_IV': ['III SEMESTER', 'IV SEMESTER'],
      'V_VI':   ['V SEMESTER',   'VI SEMESTER']
    };
    if (map[val]) {
      document.getElementById('sem1Name').value = map[val][0];
      document.getElementById('sem2Name').value = map[val][1];
    }
  }
</script>
</body>
</html>

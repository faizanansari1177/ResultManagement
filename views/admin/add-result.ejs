      .sem-panel { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .sub-header, .sub-row {
        grid-template-columns: 80px 45px 55px 45px 55px 45px 28px;
        min-width: 420px;
        gap: 2px;
      }
      .sub-header span { font-size: 0.6rem; }
      .sub-row input { font-size: 0.72rem; padding: 0.3rem 0.2rem; }

      .page-header h1 { font-size: 1.2rem; }
      .card { padding: 1rem; }
      .submit-btn { font-size: 0.95rem; padding: 0.8rem; }
    }

    @media (max-width: 480px) {
      .sub-header, .sub-row {
        grid-template-columns: 70px 40px 50px 40px 50px 40px 26px;
        min-width: 370px;
      }
    }

  </style>
</head>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Student Portal</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, #c94b7b 0%, #a0509e 35%, #3a6fc4 70%, #2255b0 100%);
      display: flex;
      flex-direction: column;
    }

    /* ── TOP NAV (logo bar) ── */
    .top-bar {
      background: white;
      padding: 0.6rem 1.5rem;
      display: flex;
      align-items: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .top-bar .brand {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
    }
    /* Logo icon made with CSS */
    .brand-icon {
      width: 44px;
      height: 44px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .brand-icon svg { width: 44px; height: 44px; }
    .brand-text { display: flex; flex-direction: column; line-height: 1.1; }
    .brand-name {
      font-size: 1.35rem;
      font-weight: 900;
      color: #1a3a8f;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .brand-sub {
      font-size: 0.6rem;
      font-weight: 800;
      color: #e53935;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    /* ── MAIN CONTENT ── */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
      padding: 3rem 1.5rem 2rem;
    }

    .page-title {
      color: white;
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 1.8rem;
      text-shadow: 0 2px 8px rgba(0,0,0,0.2);
      width: 100%;
      max-width: 420px;
    }

    /* ── CARD ── */
    .card {
      background: white;
      border-radius: 4px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.25);
      padding: 1.8rem 1.5rem;
      width: 100%;
      max-width: 420px;
    }

    /* ── INPUTS ── */
    .input-group { margin-bottom: 1rem; }
    input[type="text"],
    input[type="email"],
    input[type="password"] {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid #ccc;
      border-radius: 4px;
      font-size: 0.95rem;
      color: #333;
      transition: border-color 0.2s;
      background: white;
    }
    input::placeholder { color: #aaa; }
    input:focus { outline: none; border-color: #1a3a8f; }

    /* ── LINKS ROW ── */
    .links-row {
      display: flex;
      justify-content: space-between;
      margin: 0.3rem 0 1.3rem;
    }
    .links-row a {
      color: #1a6fc4;
      font-size: 0.88rem;
      text-decoration: none;
      font-weight: 500;
    }
    .links-row a:hover { text-decoration: underline; }

    /* ── SIGN IN BUTTON ── */
    .signin-btn {
      width: 100%;
      padding: 0.85rem;
      background: #1a5dc4;
      color: white;
      border: none;
      border-radius: 4px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      transition: background 0.2s;
      text-transform: uppercase;
    }
    .signin-btn:hover { background: #1449a0; }
    .signin-btn svg { width: 20px; height: 20px; fill: white; }

    /* ── ERROR ── */
    .error {
      background: #fff0f0;
      color: #e53935;
      padding: 0.6rem 0.9rem;
      border-radius: 4px;
      margin-bottom: 1rem;
      font-size: 0.85rem;
      border-left: 3px solid #e53935;
    }

    /* ── REGISTER LINK ── */
    .register-link {
      text-align: center;
      margin-top: 1.1rem;
      font-size: 0.88rem;
      color: #555;
    }
    .register-link a { color: #1a5dc4; text-decoration: none; font-weight: 600; }
    .register-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <!-- TOP BAR with University Logo -->
  <div class="top-bar">
    <div class="brand">
      <!-- Invertis-style logo icon -->
      <div class="brand-icon">
        <% if (settings.siteLogo) { %>
          <img src="<%= settings.siteLogo %>" alt="Logo" style="height:44px; max-width:120px; object-fit:contain;">
        <% } else { %>
          <div style="width:44px; height:44px; background:#f0f0f0; border:2px solid #ddd; border-radius:6px;"></div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">
    <div class="page-title">Sign in to your account</div>

    <div class="card">

      <% if (error) { %>
        <div class="error">⚠️ <%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="input-group">
          <input type="email" name="email" placeholder="User Name" required>
        </div>
        <div class="input-group">
          <input type="password" name="password" placeholder="Password" required>
        </div>

        <div class="links-row">
          <a href="#">Forgot Password</a>
          <a href="/register">Alumni Registration</a>
        </div>

        <button type="submit" class="signin-btn">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
          </svg>
          SIGN IN
        </button>
      </form>

      <div class="register-link">
        New student? <a href="/register">Register here</a>
      </div>

    </div>
  </div>

</body>
</html>
